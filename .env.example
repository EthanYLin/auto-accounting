# 环境配置示例文件
# 复制此文件为 .env.local 并填入实际值

# Next.js 环境配置
NODE_ENV=production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 应用配置
NEXT_PUBLIC_APP_NAME="辅助记账系统"
NEXT_PUBLIC_APP_DESCRIPTION="辅助记账系统"

# 图片优化配置
NEXT_PUBLIC_ENABLE_IMAGE_OPTIMIZATION=true

# 安全配置
NEXT_PUBLIC_CSP_ENABLED=true

# 其他配置
NEXT_PUBLIC_LOCALE=zh-CN
NEXT_PUBLIC_TIMEZONE=Asia/Shanghai

# Supabase 配置
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-url-here.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
